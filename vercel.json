{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api?path=:path*"
    },
    {
      "source": "/auth/:path*",
      "destination": "/api?path=auth/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "/api?path=uploads/:path*"
    }
  ]
}
